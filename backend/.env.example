# DCMS Evidence Bot — environment variables
# Copy this file to .env and fill in the values.

# ── API Keys ─────────────────────────────────────────────────────────────
# Required for hybrid/embeddings retrieval mode and LLM-generated answers.
# The bot works without these in BM25-only mode (no embeddings, no LLM).
OPENAI_API_KEY=sk-...

# Anthropic key. ANTHROPIC_API_KEY_DCMS is the DCMS-scoped key (preferred
# for clean per-product cost attribution at the Anthropic billing layer).
# If only ANTHROPIC_API_KEY is set, DCMS will fall back to it.
ANTHROPIC_API_KEY_DCMS=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Cost tracking store ──────────────────────────────────────────────────
# Monthly per-request usage records (<YYYY-MM>.json). Override for Fly.io
# volume mounts etc.; default is data/cache/api_usage relative to cwd.
# USAGE_STORE_DIR=data/cache/api_usage

# ── LLM Settings ─────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic          # anthropic (default) or openai
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.2
# LLM_TIMEOUT_SECONDS=30

# ── Retrieval ─────────────────────────────────────────────────────────────
# RETRIEVAL_MODE=hybrid           # bm25, embeddings, or hybrid (default)
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_BATCH_SIZE=50

# ── Evidence Thresholds ───────────────────────────────────────────────────
# EVIDENCE_MIN_TOP_SCORE=0.35
# EVIDENCE_MIN_COVERAGE=0.35
# EVIDENCE_MIN_SEPARATION=1.2

# ── Conversation / Multi-turn ─────────────────────────────────────────────
# CONVERSATION_MAX_HISTORY_TURNS=3
# CONVERSATION_MAX_HISTORY_CHARS=10000

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (appended to defaults).
# CORS_ALLOW_ORIGINS=https://your-domain.com
